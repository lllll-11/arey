# n8n Configuration
N8N_BASE_URL=https://tu-instancia.app.n8n.cloud
N8N_API_KEY=

# OpenRouter - AI principal
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL_CHAT=openai/gpt-4o-mini
OPENROUTER_MODEL_CODE=deepseek/deepseek-chat
OPENROUTER_MODEL_CALL=openai/gpt-4o-mini
OPENROUTER_MODEL_VISION=google/gemini-2.0-flash-001
OPENROUTER_MODEL_VISION_FALLBACK=qwen/qwen2.5-vl-32b-instruct
OPENROUTER_MODELS_CHAT=openai/gpt-4o-mini,google/gemini-2.0-flash-001,deepseek/deepseek-chat,meta-llama/llama-3.3-70b-instruct,qwen/qwen3.6-plus-preview:free,qwen/qwen3-coder:free
OPENROUTER_MODELS_CODE=deepseek/deepseek-chat,openai/gpt-4o-mini,google/gemini-2.0-flash-001,meta-llama/llama-3.3-70b-instruct,qwen/qwen3-coder:free
OPENROUTER_MODELS_CALL=openai/gpt-4o-mini,google/gemini-2.0-flash-001,deepseek/deepseek-chat,qwen/qwen3.6-plus-preview:free
OPENROUTER_MODELS_VISION=google/gemini-2.0-flash-001,openai/gpt-4o-mini,qwen/qwen3-vl-8b-instruct,qwen/qwen2.5-vl-32b-instruct
OPENROUTER_MAX_TOKENS_CHAT=240
OPENROUTER_MAX_TOKENS_CALL=80

# Internet lookup (busqueda web en tiempo real para Arey)
INTERNET_LOOKUP_ENABLED=true
INTERNET_LOOKUP_ALWAYS=false
INTERNET_LOOKUP_MAX_RESULTS=5

# OpenAI - Whisper STT (voz en Discord)
OPENAI_API_KEY=sk-proj-...
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_FORMAT=mp3

# ElevenLabs - Voz IA (TTS)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=XrExE9yKIg1WjnnlVkGX

# Server
PORT=3000

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Mexico_City

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/integrations/spotify/callback
SPOTIFY_SCOPE=user-read-email user-read-private user-read-playback-state user-modify-playback-state

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_OWNER_ID=
